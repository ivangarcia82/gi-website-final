---
import Layout from '../layouts/Layout.astro';
import MexicoMap from '../components/MexicoMap.astro';
import { OFFICES } from '../data/site.ts';
const initial = 'cdmx';

const phoneMap: Record<string, string> = {
  cdmx: '+52-55-7098-8100',
  bcs: '+52-612-123-4500',
  sonora: '+52-662-789-0012',
  yucatan: '+52-999-456-7890',
};

const localBusinessGraph = {
  "@context": "https://schema.org",
  "@graph": OFFICES.map((o) => ({
    "@type": ["LocalBusiness", "ProfessionalService"],
    "@id": `https://generandoideas.com/contacto#office-${o.id}`,
    "name": `Generando Ideas — ${o.name}`,
    "url": "https://generandoideas.com/contacto",
    "telephone": phoneMap[o.id] ?? o.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": o.address,
      "addressLocality": o.state,
      "addressRegion": o.state,
      "addressCountry": "MX"
    },
    "areaServed": {
      "@type": "Country",
      "name": "México"
    },
    "parentOrganization": { "@id": "https://generandoideas.com/#organization" }
  }))
};
---
<Layout title="Contacto — Generando Ideas" description="Platícanos tu idea. Respondemos en menos de 24 horas hábiles con propuesta, tiempos y presupuesto estimado.">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessGraph)} />
  <div class="page contacto">
    <section class="section" style="padding-bottom: 40px;">
      <div class="wrap">
        <span class="eyebrow reveal">Contacto</span>
        <h1 class="contact-h1 display reveal">
          Platícanos tu <span class="text-grad-word">idea.</span>
        </h1>
        <p class="contact-lead reveal">
          Respondemos en menos de 24 horas hábiles con propuesta, tiempos y presupuesto estimado.
        </p>
      </div>
    </section>

    <section class="section" style="padding-top: 0;">
      <div class="wrap contact-grid reveal">
        <div class="contact-col">
          <h2 class="contact-h2 display">
            Cuéntanos de tu proyecto
          </h2>

          <!-- Success message (hidden until valid submit) -->
          <div id="form-success" class="form-success shadow-diffuse" role="status" aria-live="polite" hidden>
            <span class="success-check" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </span>
            <h3 class="display success-title">¡Gracias, <span id="success-name"></span>!</h3>
            <p class="success-copy">
              Recibimos tu mensaje. Un ejecutivo te contactará en menos de 24 horas hábiles con una propuesta inicial.
            </p>
          </div>

          <form class="form-grid" id="contact-form" novalidate>
            <div class="field" data-field="name">
              <label for="cf-name">Nombre completo *</label>
              <input id="cf-name" name="name" placeholder="Mariana Castillo" autocomplete="name" />
              <span class="err-msg" id="cf-name-err" hidden></span>
            </div>
            <div class="field" data-field="company">
              <label for="cf-company">Empresa *</label>
              <input id="cf-company" name="company" placeholder="Grupo Lumen" autocomplete="organization" />
              <span class="err-msg" id="cf-company-err" hidden></span>
            </div>
            <div class="field" data-field="email">
              <label for="cf-email">Email *</label>
              <input id="cf-email" type="email" name="email" placeholder="mariana@grupolumen.mx" autocomplete="email" />
              <span class="err-msg" id="cf-email-err" hidden></span>
            </div>
            <div class="field" data-field="phone">
              <label for="cf-phone">Teléfono</label>
              <input id="cf-phone" name="phone" type="tel" placeholder="+52 55 1234 5678" autocomplete="tel" />
            </div>
            <div class="field" data-field="service">
              <label for="cf-service">Servicio *</label>
              <select id="cf-service" name="service">
                <option value="">Selecciona...</option>
                <option>Promocionales</option>
                <option>Fulfillment</option>
                <option>Proyectos Especiales</option>
                <option>Talleres de Personalizado</option>
                <option>Textil y Talabartería</option>
                <option>Aún no sé</option>
              </select>
              <span class="err-msg" id="cf-service-err" hidden></span>
            </div>
            <div class="field" data-field="budget">
              <label for="cf-budget">Presupuesto aprox.</label>
              <select id="cf-budget" name="budget">
                <option value="">Opcional</option>
                <option>Menos de $25,000 MXN</option>
                <option>$25,000 – $100,000</option>
                <option>$100,000 – $500,000</option>
                <option>Más de $500,000</option>
              </select>
            </div>
            <div class="field full" data-field="message">
              <label for="cf-message">Cuéntanos sobre tu proyecto *</label>
              <textarea id="cf-message" name="message" placeholder="Volumen estimado, fechas clave, objetivo de la campaña..."></textarea>
              <span class="err-msg" id="cf-message-err" hidden></span>
            </div>
            <div class="field full">
              <button type="submit" class="btn btn-primary btn-lg" style="align-self: start;">
                Enviar solicitud
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </button>
            </div>
          </form>
        </div>

        <div class="contact-col">
          <h2 class="contact-h2 display">Nuestras oficinas</h2>
          <div class="offices-wrap" style="grid-template-columns: 1fr; gap: 24px;">
            <MexicoMap />
            <div class="offices-list">
              {OFFICES.map((o) => (
                <div class:list={['office', { active: o.id === initial }]} data-office={o.id}>
                  <h3 class="office-name">{o.name}</h3>
                  <p>{o.state}</p>
                  <p>{o.address}</p>
                  <p class="office-phone">{o.phone}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .contacto .contact-h1 {
      font-size: clamp(56px, 8vw, 120px);
      margin: 20px 0 32px;
      max-width: 1100px;
    }
    .contacto .contact-lead {
      font-size: 20px;
      color: var(--gray-700);
      line-height: 1.5;
      max-width: 720px;
    }

    /* Two-column form/offices layout. Inline grid moved here so it can collapse
       to one column < 861px with no horizontal overflow. */
    .contacto .contact-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 80px;
      align-items: start;
    }
    .contacto .contact-col {
      min-width: 0;
    }

    .contacto .contact-h2 {
      font-size: 32px;
      margin: 0 0 24px;
      letter-spacing: -0.02em;
    }

    /* Success card — uses an inline SVG check instead of a bare glyph. */
    .contacto .form-success {
      padding: 40px;
      background: var(--blue-100);
      border-radius: var(--radius-lg);
      border: 1.5px solid var(--blue-700);
    }
    .contacto .success-check {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--blue-700);
      color: #fff;
      margin-bottom: 18px;
    }
    .contacto .success-title {
      font-size: 28px;
      margin: 0 0 8px;
    }
    .contacto .success-copy {
      margin: 0;
      color: var(--gray-700);
      line-height: 1.55;
    }

    /* Office name keeps the global ".office h4" look now that it is an h3
       (heading order h1 to h2 to h3, no skips). */
    .contacto .office-name {
      font-family: var(--font-display);
      font-size: 24px;
      margin: 0 0 8px;
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    /* Comfortable tap targets on the form controls (>= 44px). */
    .contacto .field input,
    .contacto .field select,
    .contacto .field .btn {
      min-height: 48px;
    }

    @media (max-width: 860px) {
      .contacto .contact-grid {
        grid-template-columns: 1fr;
        gap: 56px;
      }
    }

    /* Reduced-motion users get no stagger delay; the global reduced-motion rule
       keeps .reveal fully visible. */
    @media (prefers-reduced-motion: no-preference) {
      .contacto .contact-h1 { transition-delay: 0.06s; }
      .contacto .contact-lead { transition-delay: 0.12s; }
    }
  </style>

  <script>
    import { initMotion, gsap, ScrollTrigger, prefersReducedMotion } from '../lib/motion';

    initMotion();

    // Calm stagger on the form fields (transform/opacity only), guarded.
    if (!prefersReducedMotion()) {
      const fields = gsap.utils.toArray<HTMLElement>('#contact-form .field');
      if (fields.length) {
        gsap.from(fields, {
          y: 18,
          opacity: 0,
          duration: 0.6,
          ease: 'power2.out',
          stagger: 0.05,
          scrollTrigger: { trigger: '#contact-form', start: 'top 82%', once: true },
        });
      }
      document.addEventListener(
        'astro:before-swap',
        () => ScrollTrigger.getAll().forEach((t) => t.kill()),
        { once: true },
      );
    }

    // ---- Office / map coordination ----
    const groups = Array.from(document.querySelectorAll<HTMLElement>('.map-pin-group'));
    const offices = Array.from(document.querySelectorAll<HTMLElement>('.office'));
    function setActiveOffice(id: string | undefined) {
      if (!id) return;
      groups.forEach((g) => g.classList.toggle('active', g.dataset.office === id));
      offices.forEach((o) => o.classList.toggle('active', o.dataset.office === id));
    }
    groups.forEach((g) => g.addEventListener('click', () => setActiveOffice(g.dataset.office)));
    offices.forEach((o) => o.addEventListener('click', () => setActiveOffice(o.dataset.office)));

    // ---- Contact form validation (ports validate() from pages.jsx) ----
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('form-success') as HTMLElement | null;
    const successName = document.getElementById('success-name');

    function setError(field: string, message: string | null) {
      const wrap = form?.querySelector<HTMLElement>(`.field[data-field="${field}"]`);
      if (!wrap) return;
      const msg = wrap.querySelector<HTMLElement>('.err-msg');
      const input = wrap.querySelector<HTMLElement>('input, select, textarea');
      wrap.classList.toggle('error', !!message);
      if (input) {
        if (message) {
          input.setAttribute('aria-invalid', 'true');
          if (msg?.id) input.setAttribute('aria-describedby', msg.id);
        } else {
          input.removeAttribute('aria-invalid');
          input.removeAttribute('aria-describedby');
        }
      }
      if (msg) {
        msg.textContent = message ?? '';
        msg.hidden = !message;
      }
    }

    form?.addEventListener('submit', (ev) => {
      ev.preventDefault();
      if (!form) return;
      const data = new FormData(form);
      const get = (k: string) => String(data.get(k) ?? '').trim();
      const name = get('name');
      const email = get('email');
      const company = get('company');
      const service = get('service');
      const message = get('message');

      const errors: Record<string, string> = {};
      if (!name) errors.name = 'Nombre requerido';
      if (!email) errors.email = 'Email requerido';
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.email = 'Email inválido';
      if (!company) errors.company = 'Empresa requerida';
      if (!service) errors.service = 'Selecciona un servicio';
      if (!message || message.length < 10) errors.message = 'Cuéntanos un poco más (min 10 caracteres)';

      ['name', 'email', 'company', 'service', 'message'].forEach((f) => setError(f, errors[f] ?? null));

      if (Object.keys(errors).length === 0) {
        if (successName) successName.textContent = name.split(' ')[0];
        form.style.display = 'none';
        if (success) {
          success.hidden = false;
          success.style.display = 'block';
        }
      } else {
        // Move focus to the first field with an error for keyboard/SR users.
        const firstErr = Object.keys(errors)[0];
        form
          .querySelector<HTMLElement>(`.field[data-field="${firstErr}"] input, .field[data-field="${firstErr}"] select, .field[data-field="${firstErr}"] textarea`)
          ?.focus();
      }
    });
  </script>
</Layout>
