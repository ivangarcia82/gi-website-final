---
import Layout from '../layouts/Layout.astro';
import MexicoMap from '../components/MexicoMap.astro';
import { OFFICES } from '../data/site.ts';
const initial = 'cdmx';
---
<Layout title="Contacto — Generando Ideas" description="Platícanos tu idea. Respondemos en menos de 24 horas hábiles con propuesta, tiempos y presupuesto estimado.">
  <div class="page">
    <section class="section" style="padding-bottom: 40px;">
      <div class="wrap">
        <span class="eyebrow">Contacto</span>
        <h1 class="display" style="font-size: clamp(56px, 8vw, 120px); margin: 20px 0 32px; max-width: 1100px;">
          Platícanos tu <em style="font-style: italic; color: var(--orange-500);">idea.</em>
        </h1>
        <p style="font-size: 20px; color: var(--gray-700); line-height: 1.5; max-width: 720px;">
          Respondemos en menos de 24 horas hábiles con propuesta, tiempos y presupuesto estimado.
        </p>
      </div>
    </section>

    <section class="section" style="padding-top: 0;">
      <div class="wrap reveal" style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 80px;">
        <div>
          <h3 class="display" style="font-size: 32px; margin: 0 0 24px; letter-spacing: -0.02em;">
            Cuéntanos de tu proyecto
          </h3>

          <!-- Success message (hidden until valid submit) -->
          <div id="form-success" style="display: none; padding: 40px; background: var(--blue-100); border-radius: var(--radius-lg); border: 1.5px solid var(--blue-700);">
            <div style="font-size: 48px; margin-bottom: 16px;">✓</div>
            <h4 class="display" style="font-size: 28px; margin: 0 0 8px;">¡Gracias, <span id="success-name"></span>!</h4>
            <p style="margin: 0; color: var(--gray-700);">
              Recibimos tu mensaje. Un ejecutivo te contactará en menos de 24 horas hábiles con una propuesta inicial.
            </p>
          </div>

          <form class="form-grid" id="contact-form" novalidate>
            <div class="field" data-field="name">
              <label>Nombre completo *</label>
              <input name="name" placeholder="María López" />
              <span class="err-msg" hidden></span>
            </div>
            <div class="field" data-field="company">
              <label>Empresa *</label>
              <input name="company" placeholder="Acme Corp" />
              <span class="err-msg" hidden></span>
            </div>
            <div class="field" data-field="email">
              <label>Email *</label>
              <input type="email" name="email" placeholder="maria@acme.mx" />
              <span class="err-msg" hidden></span>
            </div>
            <div class="field" data-field="phone">
              <label>Teléfono</label>
              <input name="phone" placeholder="+52 55 1234 5678" />
            </div>
            <div class="field" data-field="service">
              <label>Servicio *</label>
              <select name="service">
                <option value="">Selecciona...</option>
                <option>Promocionales</option>
                <option>Fulfillment</option>
                <option>Proyectos Especiales</option>
                <option>Talleres de Personalizado</option>
                <option>Textil y Talabartería</option>
                <option>Aún no sé</option>
              </select>
              <span class="err-msg" hidden></span>
            </div>
            <div class="field" data-field="budget">
              <label>Presupuesto aprox.</label>
              <select name="budget">
                <option value="">Opcional</option>
                <option>Menos de $25,000 MXN</option>
                <option>$25,000 – $100,000</option>
                <option>$100,000 – $500,000</option>
                <option>Más de $500,000</option>
              </select>
            </div>
            <div class="field full" data-field="message">
              <label>Cuéntanos sobre tu proyecto *</label>
              <textarea name="message" placeholder="Volumen estimado, fechas clave, objetivo de la campaña..."></textarea>
              <span class="err-msg" hidden></span>
            </div>
            <div class="field full">
              <button type="submit" class="btn btn-primary btn-lg" style="align-self: start;">
                Enviar solicitud
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </button>
            </div>
          </form>
        </div>

        <div>
          <h3 class="display" style="font-size: 32px; margin: 0 0 24px; letter-spacing: -0.02em;">Nuestras oficinas</h3>
          <div class="offices-wrap" style="grid-template-columns: 1fr; gap: 24px;">
            <MexicoMap />
            <div class="offices-list">
              {OFFICES.map((o) => (
                <div class:list={['office', { active: o.id === initial }]} data-office={o.id}>
                  <h4>{o.name}</h4>
                  <p>{o.state}</p>
                  <p>{o.address}</p>
                  <p class="office-phone">{o.phone}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    // ---- Office / map coordination ----
    const groups = Array.from(document.querySelectorAll<HTMLElement>('.map-pin-group'));
    const offices = Array.from(document.querySelectorAll<HTMLElement>('.office'));
    function setActiveOffice(id: string | undefined) {
      if (!id) return;
      groups.forEach((g) => g.classList.toggle('active', g.dataset.office === id));
      offices.forEach((o) => o.classList.toggle('active', o.dataset.office === id));
    }
    groups.forEach((g) => g.addEventListener('click', () => setActiveOffice(g.dataset.office)));
    offices.forEach((o) => o.addEventListener('click', () => setActiveOffice(o.dataset.office)));

    // ---- Contact form validation (ports validate() from pages.jsx) ----
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('form-success') as HTMLElement | null;
    const successName = document.getElementById('success-name');

    function setError(field: string, message: string | null) {
      const wrap = form?.querySelector<HTMLElement>(`.field[data-field="${field}"]`);
      if (!wrap) return;
      const msg = wrap.querySelector<HTMLElement>('.err-msg');
      wrap.classList.toggle('error', !!message);
      if (msg) {
        msg.textContent = message ?? '';
        msg.hidden = !message;
      }
    }

    form?.addEventListener('submit', (ev) => {
      ev.preventDefault();
      if (!form) return;
      const data = new FormData(form);
      const get = (k: string) => String(data.get(k) ?? '').trim();
      const name = get('name');
      const email = get('email');
      const company = get('company');
      const service = get('service');
      const message = get('message');

      const errors: Record<string, string> = {};
      if (!name) errors.name = 'Nombre requerido';
      if (!email) errors.email = 'Email requerido';
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.email = 'Email inválido';
      if (!company) errors.company = 'Empresa requerida';
      if (!service) errors.service = 'Selecciona un servicio';
      if (!message || message.length < 10) errors.message = 'Cuéntanos un poco más (min 10 caracteres)';

      ['name', 'email', 'company', 'service', 'message'].forEach((f) => setError(f, errors[f] ?? null));

      if (Object.keys(errors).length === 0) {
        if (successName) successName.textContent = name.split(' ')[0];
        form.style.display = 'none';
        if (success) success.style.display = 'block';
      }
    });
  </script>
</Layout>
