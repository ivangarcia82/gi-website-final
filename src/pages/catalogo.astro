---
import Layout from '../layouts/Layout.astro';
import { CATALOGS, CATALOG_CATEGORIES } from '../data/site.ts';
---
<Layout
  title="Generando Ideas | Catálogo de Productos Promocionales"
  description="Encuentra artículos promocionales, regalos corporativos y soluciones personalizadas para fortalecer la presencia de tu marca."
>
  <div class="page catalogo">
    <section class="section cat-hero">
      <div class="wrap">
        <span class="eyebrow reveal">Catálogos 2026</span>
        <h1 class="display cat-h1 reveal">
          Todo lo que tu marca necesita, en un <span class="text-grad-word">solo lugar.</span>
        </h1>
        <p class="cat-lead reveal">
          Encuentra artículos promocionales, regalos corporativos y soluciones personalizadas
          para fortalecer la presencia de tu marca.
        </p>
      </div>
    </section>

    <section class="section cat-carousel-sec">
      <div class="wrap reveal">
        <div class="cat-sec-head">
          <h2 class="display cat-sec-title">Explora nuestros catálogos</h2>
          <span class="cat-sec-hint">Haz clic para abrir</span>
        </div>

        <div class="cat-filter catalog-filter" id="catalog-filter" role="group" aria-label="Filtrar catálogos por categoría">
          {CATALOG_CATEGORIES.map((c, i) => (
            <button
              class:list={['chip', { active: i === 0 }]}
              data-cat={c}
              type="button"
              aria-pressed={i === 0 ? 'true' : 'false'}
            >{c}</button>
          ))}
        </div>

        <div class="cat-grid" id="catalog-grid">
          {CATALOGS.map((c) => (
            <a
              class="cat-card"
              data-tag={c.tag}
              href={c.flipbook}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Abrir el catálogo ${c.name} en una nueva pestaña`}
            >
              <div class="cat-card-img"><img src={c.img} alt={`Portada del catálogo ${c.name}`} loading="lazy" /></div>
              <div class="cat-card-body">
                <h3>{c.name}</h3>
                <span>{c.tag}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>

  <style>
    .cat-hero {
      padding-bottom: clamp(40px, 6vh, 56px);
    }
    .cat-h1 {
      font-size: clamp(48px, 8vw, 116px);
      line-height: 0.92;
      letter-spacing: -0.035em;
      margin: 18px 0 24px;
      max-width: 16ch;
    }
    .cat-lead {
      font-size: 18px;
      color: var(--gray-700);
      line-height: 1.55;
      max-width: 52ch;
      margin: 0;
    }
    .cat-carousel-sec {
      padding-top: 0;
    }
    .cat-sec-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 20px;
      margin: 0 0 24px;
    }
    .cat-sec-title {
      font-size: clamp(26px, 4vw, 36px);
      letter-spacing: -0.02em;
      margin: 0;
    }
    .cat-sec-hint {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--gray-700);
      flex: 0 0 auto;
    }
    .catalog-filter {
      margin: 0 0 28px;
    }
    /* Tap-target floor: bring the global .chip to >= 44px. */
    .catalog-filter .chip {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }
    .cat-card.is-hidden {
      display: none;
    }
    .cat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: clamp(16px, 2vw, 24px);
    }
    @media (max-width: 980px) {
      .cat-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .cat-grid .cat-card {
      flex: initial;
      text-decoration: none;
      color: inherit;
    }
    @media (max-width: 860px) {
      .cat-sec-head {
        flex-direction: column;
        align-items: flex-start;
        gap: 6px;
      }
    }
    @media (max-width: 520px) {
      .cat-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (prefers-reduced-motion: no-preference) {
      .cat-h1 { transition-delay: 0.06s; }
      .cat-lead { transition-delay: 0.12s; }
    }
  </style>

  <script>
    // Category filter: toggle catalog cards by their tag (no re-render needed).
    const filter = document.getElementById('catalog-filter');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('#catalog-grid .cat-card'));

    filter?.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const cat = chip.dataset.cat ?? 'Todos';
        filter.querySelectorAll('.chip').forEach((c) => {
          const active = c === chip;
          c.classList.toggle('active', active);
          c.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
        cards.forEach((card) => {
          card.classList.toggle('is-hidden', cat !== 'Todos' && card.dataset.tag !== cat);
        });
      });
    });
  </script>

  <script>
    import { initMotion, ScrollTrigger } from '../lib/motion';

    initMotion();

    document.addEventListener(
      'astro:before-swap',
      () => {
        ScrollTrigger.getAll().forEach((t) => t.kill());
        document.body.style.overflow = '';
      },
      { once: true },
    );
  </script>
</Layout>
