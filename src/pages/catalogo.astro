---
import Layout from '../layouts/Layout.astro';
import { CATALOGS } from '../data/site.ts';
---
<Layout
  title="Generando Ideas | Catálogo de Productos Promocionales"
  description="Encuentra artículos promocionales, regalos corporativos y soluciones personalizadas para fortalecer la presencia de tu marca."
>
  <div class="page catalogo">
    <section class="section cat-hero">
      <div class="wrap">
        <span class="eyebrow reveal">Catálogos 2026</span>
        <h1 class="display cat-h1 reveal">
          Todo lo que tu marca necesita, en un <span class="text-grad-word">solo lugar.</span>
        </h1>
        <p class="cat-lead reveal">
          Encuentra artículos promocionales, regalos corporativos y soluciones personalizadas
          para fortalecer la presencia de tu marca.
        </p>
      </div>
    </section>

    <section class="section cat-carousel-sec">
      <div class="wrap reveal">
        <div class="cat-sec-head">
          <h2 class="display cat-sec-title">Explora nuestros catálogos</h2>
          <span class="cat-sec-hint">Haz clic para abrir</span>
        </div>
        <div class="cat-grid">
          {CATALOGS.map((c) => (
            <a
              class="cat-card"
              href={c.flipbook}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Abrir el catálogo ${c.name} en una nueva pestaña`}
            >
              <div class="cat-card-img"><img src={c.img} alt={`Portada del catálogo ${c.name}`} loading="lazy" /></div>
              <div class="cat-card-body">
                <h3>{c.name}</h3>
                <span>{c.tag}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>

  <style>
    .cat-hero {
      padding-bottom: clamp(40px, 6vh, 56px);
    }
    .cat-h1 {
      font-size: clamp(48px, 8vw, 116px);
      line-height: 0.92;
      letter-spacing: -0.035em;
      margin: 18px 0 24px;
      max-width: 16ch;
    }
    .cat-lead {
      font-size: 18px;
      color: var(--gray-700);
      line-height: 1.55;
      max-width: 52ch;
      margin: 0;
    }
    .cat-carousel-sec {
      padding-top: 0;
    }
    .cat-sec-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 20px;
      margin: 0 0 24px;
    }
    .cat-sec-title {
      font-size: clamp(26px, 4vw, 36px);
      letter-spacing: -0.02em;
      margin: 0;
    }
    .cat-sec-hint {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--gray-700);
      flex: 0 0 auto;
    }
    .cat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: clamp(16px, 2vw, 24px);
    }
    @media (max-width: 980px) {
      .cat-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .cat-grid .cat-card {
      flex: initial;
      text-decoration: none;
      color: inherit;
    }
    @media (max-width: 860px) {
      .cat-sec-head {
        flex-direction: column;
        align-items: flex-start;
        gap: 6px;
      }
    }
    @media (max-width: 520px) {
      .cat-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (prefers-reduced-motion: no-preference) {
      .cat-h1 { transition-delay: 0.06s; }
      .cat-lead { transition-delay: 0.12s; }
    }
  </style>

  <script>
    import { initMotion, ScrollTrigger } from '../lib/motion';

    initMotion();

    document.addEventListener(
      'astro:before-swap',
      () => {
        ScrollTrigger.getAll().forEach((t) => t.kill());
        document.body.style.overflow = '';
      },
      { once: true },
    );
  </script>
</Layout>
