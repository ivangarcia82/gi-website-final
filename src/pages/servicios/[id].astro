---
import Layout from '../../layouts/Layout.astro';
import { SERVICE_DETAILS, ROUTES } from '../../data/site.ts';

export function getStaticPaths() {
  return Object.keys(SERVICE_DETAILS).map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const s = SERVICE_DETAILS[id as string];
if (!s) return Astro.redirect('/servicios');
const other = Object.entries(SERVICE_DETAILS).filter(([k]) => k !== id);

// Shared "how we work" process — keeps every service page feeling complete
// without inventing per-service copy that the team would have to maintain.
const PROCESS = [
  { t: 'Briefing', d: 'Escuchamos tu objetivo, audiencia y presupuesto para entender qué necesita tu marca.' },
  { t: 'Propuesta', d: 'Diseñamos una selección a medida con cotización clara y tiempos de entrega definidos.' },
  { t: 'Producción', d: 'Personalizamos y producimos con control de calidad en cada etapa del proceso.' },
  { t: 'Entrega', d: 'Coordinamos la logística y damos seguimiento hasta que el pedido llega a tus manos.' },
];

// Restrained accent: gradient at most ONE word of the H1, and only when the
// service title has more than one word (gradienting a single-word title would
// gradient the whole heading, which is banned). The first word carries it.
const titleWords = s.title.split(' ');
const gradFirst = titleWords.length > 1;
const headFirst = titleWords[0];
const headRest = gradFirst ? titleWords.slice(1).join(' ') : '';

const svcCanonical = new URL(`/servicios/${id}`, Astro.site).href;

const servicePageJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": s.title,
      "description": s.intro,
      "image": s.hero,
      "url": svcCanonical,
      "provider": { "@id": "https://generandoideas.com/#organization" },
      "areaServed": { "@type": "Country", "name": "México" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": svcCanonical }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://generandoideas.com/" },
        { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://generandoideas.com/servicios" },
        { "@type": "ListItem", "position": 3, "name": s.title, "item": svcCanonical }
      ]
    }
  ]
};
---
<Layout
  title={s.seoTitle ?? `${s.title} — Generando Ideas`}
  description={s.seoDescription ?? `${s.tagline} ${s.intro}`}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(servicePageJsonLd)} />
  <div class="page svc-detail">
    <section class="section svc-intro">
      <div class="wrap">
        <a class="btn btn-ghost back-link" href={ROUTES.services}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M11 18l-6-6 6-6" />
          </svg>
          Todos los servicios
        </a>
        <span class="eyebrow">Servicio {s.num}</span>
        <h1 class="display svc-h1">
          {gradFirst ? (
            <><span class="text-grad-word">{headFirst}</span> {headRest}</>
          ) : (
            s.title
          )}
        </h1>
        <p class="svc-tagline" style={`--svc-color: ${s.color};`}>{s.tagline}</p>
      </div>
    </section>

    <section class="svc-hero-wrap">
      <div class="wrap">
        <div class="svc-hero-stage" data-hero-stage>
          <img
            src={s.hero}
            alt={`${s.title} — ${s.tagline}`}
            width="1400"
            height="612"
            loading="lazy"
            decoding="async"
            data-hero-img
          />
        </div>
      </div>
    </section>

    <section class="section svc-includes">
      <div class="wrap svc-includes-grid reveal">
        <div class="svc-includes-lead">
          <span class="eyebrow">Por qué nosotros</span>
          <h2 class="display svc-h2">
            Lo que <span class="text-accent">incluye</span>
          </h2>
          <p class="svc-intro-copy">{s.intro}</p>
          <div class="svc-examples">
            {s.examples.map((e) => (
              <span class="svc-chip">{e}</span>
            ))}
          </div>
        </div>
        <ul class="svc-features" style={`--svc-color: ${s.color};`}>
          {s.features.map((f, i) => (
            <li class="svc-feature">
              <span class="svc-feature-num">0{i + 1}</span>
              <h3 class="svc-feature-t">{f.t}</h3>
              <p class="svc-feature-d">{f.d}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section svc-process">
      <div class="wrap reveal">
        <div class="svc-process-head">
          <span class="eyebrow">Cómo trabajamos</span>
          <h2 class="display svc-h2">De la idea a tus manos, en <span class="text-accent">4 pasos</span></h2>
        </div>
        <ol class="svc-steps">
          {PROCESS.map((p, i) => (
            <li class="svc-step">
              <span class="svc-step-num">0{i + 1}</span>
              <h3 class="svc-step-t">{p.t}</h3>
              <p class="svc-step-d">{p.d}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section section-dark svc-end-cta">
      <div class="wrap svc-cta-inner">
        <h2 class="display svc-cta-h">
          ¿Te interesa <span class="text-accent">{s.title}</span>?
        </h2>
        <p class="svc-cta-sub">
          Hablemos. Respuesta en menos de 24 horas hábiles.
        </p>
        <div class="svc-cta-actions">
          <span class="magnetic" data-magnetic>
            <a href={ROUTES.contact} class="btn btn-accent btn-lg">
              Cotizar ahora
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          </span>
          <a href={ROUTES.catalog} class="btn btn-ghost-light btn-lg">Ver e-store</a>
        </div>
      </div>
    </section>

    <section class="section section-alt svc-more">
      <div class="wrap">
        <span class="eyebrow">Más servicios</span>
        <h2 class="display svc-h2 svc-more-h">Explora nuestro portafolio</h2>
        <div class="svc-more-grid">
          {other.map(([k, v]) => (
            <a href={ROUTES.service(k)} class="svc-more-card reveal" style={`--svc-tint: ${v.color};`}>
              <span class="svc-more-num">{v.num}</span>
              <h3 class="svc-more-t">{v.title}</h3>
              <span class="svc-more-arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* ---- Intro ------------------------------------------------------------ */
  .svc-intro {
    padding-bottom: 40px;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    min-height: 44px;
  }
  .back-link svg {
    transition: transform 0.25s cubic-bezier(.2,.8,.2,1);
  }
  @media (prefers-reduced-motion: no-preference) {
    .back-link:hover svg {
      transform: translateX(-3px);
    }
  }
  .svc-h1 {
    font-size: clamp(56px, 8vw, 128px);
    margin: 20px 0 24px;
    letter-spacing: -0.035em;
    line-height: 0.92;
    max-width: 1100px;
  }
  .svc-tagline {
    font-size: clamp(22px, 3vw, 26px);
    font-family: var(--font-display);
    font-style: italic;
    margin: 0;
    letter-spacing: -0.01em;
    max-width: 720px;
    /* Keep the service hue identity but darken it enough to pass AA on paper. */
    color: var(--ink-soft);
    color: color-mix(in srgb, var(--svc-color, var(--blue-700)), var(--ink) 40%);
  }

  /* ---- Hero image (zoom-parallax) -------------------------------------- */
  .svc-hero-wrap {
    padding: 8px 0 60px;
  }
  .svc-hero-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 28px 60px -28px rgba(67, 69, 74, 0.22);
  }
  .svc-hero-stage img {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.04);
    will-change: transform;
  }
  .svc-hero-stage::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(67, 69, 74, 0.06) 0%,
      transparent 30%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ---- Lo que incluye --------------------------------------------------- */
  .svc-includes {
    padding-top: 0;
  }
  .svc-includes-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
  }
  .svc-h2 {
    font-size: clamp(34px, 4.5vw, 48px);
    margin: 12px 0 24px;
    letter-spacing: -0.02em;
    line-height: 1.02;
  }
  .svc-intro-copy {
    font-size: 17px;
    line-height: 1.65;
    color: var(--gray-700);
    margin: 0 0 32px;
    max-width: 46ch;
  }
  .svc-examples {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .svc-chip {
    padding: 8px 14px;
    background: var(--paper-2);
    border: 1px solid var(--gray-200);
    border-radius: 999px;
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--ink-soft);
  }

  .svc-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }
  .svc-feature {
    position: relative;
    padding: 28px;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    background: #fff;
    transition: transform 0.25s cubic-bezier(.2,.8,.2,1),
                box-shadow 0.25s cubic-bezier(.2,.8,.2,1),
                border-color 0.25s ease;
  }
  /* Subtle hover tint + lift (transform/opacity-safe). */
  @media (prefers-reduced-motion: no-preference) {
    .svc-feature:hover {
      transform: translateY(-3px);
    }
  }
  .svc-feature:hover {
    border-color: var(--gray-300);
    box-shadow: 0 18px 40px -24px rgba(67, 69, 74, 0.20);
  }
  .svc-feature::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
    background: linear-gradient(180deg, rgba(99, 101, 105, 0.05), transparent 70%);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .svc-feature:hover::before {
    opacity: 1;
  }
  .svc-feature-num {
    position: relative;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    color: color-mix(in srgb, var(--svc-color, var(--blue-700)), var(--ink) 52%);
  }
  .svc-feature-t {
    position: relative;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    margin: 8px 0;
    letter-spacing: -0.015em;
  }
  .svc-feature-d {
    position: relative;
    color: var(--gray-700);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
  }

  /* ---- Cómo trabajamos (proceso) --------------------------------------- */
  .svc-process-head {
    max-width: 720px;
    margin-bottom: 40px;
  }
  .svc-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .svc-step {
    position: relative;
    padding: 28px 24px;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    background: #fff;
    transition: transform 0.25s cubic-bezier(.2,.8,.2,1),
                box-shadow 0.25s cubic-bezier(.2,.8,.2,1),
                border-color 0.25s ease;
  }
  .svc-step::after {
    content: "";
    position: absolute;
    top: 0;
    left: 24px;
    width: 28px;
    height: 3px;
    background: var(--orange-500);
    border-radius: 0 0 3px 3px;
  }
  @media (prefers-reduced-motion: no-preference) {
    .svc-step:hover {
      transform: translateY(-3px);
    }
  }
  .svc-step:hover {
    border-color: var(--gray-300);
    box-shadow: 0 18px 40px -24px rgba(67, 69, 74, 0.20);
  }
  .svc-step-num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--orange-700);
  }
  .svc-step-t {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    margin: 10px 0 8px;
    letter-spacing: -0.015em;
  }
  .svc-step-d {
    color: var(--gray-700);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
  }

  /* ---- Dark CTA --------------------------------------------------------- */
  .svc-cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .svc-cta-h {
    font-size: clamp(40px, 6vw, 80px);
    letter-spacing: -0.03em;
    margin: 0 auto 24px;
    max-width: 900px;
    line-height: 0.98;
  }
  .svc-cta-sub {
    color: var(--gray-300);
    font-size: 18px;
    max-width: 600px;
    margin: 0 auto 32px;
    line-height: 1.5;
  }
  .svc-cta-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }
  .magnetic {
    display: inline-block;
  }
  .svc-end-cta .btn-lg {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .btn-ghost-light {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.32);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }
  .btn-ghost-light:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
  }
  @media (prefers-reduced-motion: no-preference) {
    .magnetic {
      will-change: transform;
    }
  }

  /* ---- Más servicios ---------------------------------------------------- */
  .svc-more-h {
    margin-bottom: 32px;
  }
  .svc-more-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .svc-more-card {
    position: relative;
    display: flex;
    flex-direction: column;
    text-align: left;
    padding: 24px;
    min-height: 132px;
    background: #fff;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.25s cubic-bezier(.2,.8,.2,1),
                box-shadow 0.25s cubic-bezier(.2,.8,.2,1),
                border-color 0.25s ease;
  }
  /* Hover tint keyed to each service's own brand color (low alpha). */
  .svc-more-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--svc-tint);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .svc-more-card:hover::before {
    opacity: 0.05;
  }
  .svc-more-card:hover {
    border-color: var(--gray-300);
    box-shadow: 0 18px 40px -24px rgba(67, 69, 74, 0.20);
  }
  @media (prefers-reduced-motion: no-preference) {
    .svc-more-card:hover {
      transform: translateY(-3px);
    }
  }
  .svc-more-num {
    position: relative;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    color: color-mix(in srgb, var(--svc-tint, var(--blue-700)), var(--ink) 52%);
  }
  .svc-more-t {
    position: relative;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    margin: 8px 0 0;
    letter-spacing: -0.02em;
  }
  .svc-more-arrow {
    position: relative;
    margin-top: auto;
    padding-top: 16px;
    color: var(--gray-300);
    transition: color 0.25s ease, transform 0.25s cubic-bezier(.2,.8,.2,1);
  }
  .svc-more-card:hover .svc-more-arrow {
    color: var(--ink);
  }
  @media (prefers-reduced-motion: no-preference) {
    .svc-more-card:hover .svc-more-arrow {
      transform: translateX(3px);
    }
  }

  /* ---- Mobile collapse -------------------------------------------------- */
  @media (max-width: 860px) {
    .svc-includes-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .svc-more-grid {
      grid-template-columns: 1fr 1fr;
    }
    .svc-steps {
      grid-template-columns: 1fr 1fr;
    }
    .svc-hero-stage {
      aspect-ratio: 4 / 3;
    }
  }
  @media (max-width: 560px) {
    .svc-more-grid {
      grid-template-columns: 1fr;
    }
    .svc-steps {
      grid-template-columns: 1fr;
    }
  }

  /* Reduced motion: hold the hero at its base scale, no parallax. */
  @media (prefers-reduced-motion: reduce) {
    .svc-hero-stage img {
      transform: scale(1.04);
      will-change: auto;
    }
  }
</style>

<script>
  import { initMotion, gsap, ScrollTrigger, prefersReducedMotion } from '../../lib/motion';

  initMotion();

  const teardown: Array<() => void> = [];

  if (!prefersReducedMotion()) {
    // Hero zoom-parallax (transform only), mirroring the homepage Hero scrub.
    const img = document.querySelector<HTMLElement>('[data-hero-img]');
    const stage = document.querySelector<HTMLElement>('[data-hero-stage]');
    if (img && stage) {
      gsap.fromTo(
        img,
        { scale: 1.04 },
        {
          scale: 1.14,
          ease: 'none',
          scrollTrigger: {
            trigger: stage,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        },
      );
    }

    // Staggered reveal on the "más servicios" cards.
    const cards = gsap.utils.toArray<HTMLElement>('.svc-more-card');
    if (cards.length) {
      gsap.fromTo(
        cards,
        { autoAlpha: 0, y: 24 },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.7,
          ease: 'power2.out',
          stagger: 0.08,
          scrollTrigger: { trigger: '.svc-more-grid', start: 'top 85%', once: true },
        },
      );
    }

    // Magnetic CTA — fine-pointer + motion only.
    const wrap = document.querySelector<HTMLElement>('[data-magnetic]');
    if (wrap && window.matchMedia('(pointer: fine)').matches) {
      const xTo = gsap.quickTo(wrap, 'x', { duration: 0.4, ease: 'power3' });
      const yTo = gsap.quickTo(wrap, 'y', { duration: 0.4, ease: 'power3' });
      const onMove = (e: PointerEvent) => {
        const r = wrap.getBoundingClientRect();
        xTo((e.clientX - (r.left + r.width / 2)) * 0.35);
        yTo((e.clientY - (r.top + r.height / 2)) * 0.35);
      };
      const onLeave = () => { xTo(0); yTo(0); };
      wrap.addEventListener('pointermove', onMove);
      wrap.addEventListener('pointerleave', onLeave);
      teardown.push(() => {
        wrap.removeEventListener('pointermove', onMove);
        wrap.removeEventListener('pointerleave', onLeave);
        gsap.killTweensOf(wrap);
      });
    }
  } else {
    // Reduced motion: the GSAP reveal never runs, so ensure cards are visible.
    document.querySelectorAll<HTMLElement>('.svc-more-card').forEach((el) => {
      el.style.opacity = '1';
      el.style.visibility = 'visible';
    });
  }

  document.addEventListener(
    'astro:before-swap',
    () => {
      ScrollTrigger.getAll().forEach((t) => t.kill());
      teardown.forEach((fn) => fn());
    },
    { once: true },
  );
</script>
