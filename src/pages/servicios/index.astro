---
import Layout from '../../layouts/Layout.astro';
import ServicesShowcase from '../../components/ServicesShowcase.astro';
import { SERVICES, ROUTES } from '../../data/site.ts';
---
<Layout
  title="Servicios — Generando Ideas"
  description="Cinco servicios, una sola relación: promocionales, fulfillment, proyectos especiales, talleres y textil & talabartería."
>
  <div class="page svc-index">
    <!-- ===== Hero ===== -->
    <section class="section svc-hero-sec">
      <div class="wrap">
        <span class="eyebrow svc-rev" data-svc-rev>Servicios</span>
        <h1 class="display svc-h1 svc-rev" data-svc-rev>
          Cinco servicios, <span class="text-grad-word">una sola</span> relación.
        </h1>
        <div class="svc-hero-foot">
          <p class="svc-lede svc-rev" data-svc-rev>
            Tu promocional puede ser una pieza, o puede ser un ecosistema completo: producción,
            almacenamiento, envío, experiencia. Elige hasta donde quieras llegar.
          </p>
          <ul class="svc-index-list svc-rev" data-svc-rev aria-label="Índice de servicios">
            {SERVICES.map((s) => (
              <li>
                <a href={ROUTES.service(s.id)}>
                  <span class="n">{s.num}</span>
                  <span class="t">{s.title}</span>
                  <svg class="ar" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ===== Mosaic showcase ===== -->
    <section class="section svc-mosaic-sec section-alt">
      <div class="wrap">
        <div class="svc-mosaic-head">
          <span class="eyebrow svc-rev" data-svc-rev>El ecosistema completo</span>
          <h2 class="svc-rev" data-svc-rev>
            Una ventanilla, <span class="text-accent">cinco caminos</span> para tu marca.
          </h2>
        </div>
        <div class="svc-mosaic-mount" data-svc-mosaic>
          <ServicesShowcase layout="mosaic" />
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* ===== Hero ===== */
  .svc-hero-sec {
    padding-bottom: clamp(48px, 7vh, 88px);
  }
  .svc-h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 120px);
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-weight: 700;
    max-width: 1100px;
    margin: 18px 0 0;
    text-wrap: balance;
  }

  .svc-hero-foot {
    display: grid;
    grid-template-columns: 1fr minmax(0, 360px);
    gap: clamp(32px, 6vw, 80px);
    align-items: end;
    margin-top: clamp(36px, 6vh, 64px);
    padding-top: clamp(28px, 4vh, 44px);
    border-top: 1px solid var(--gray-200);
  }
  .svc-lede {
    font-size: clamp(18px, 2.4vw, 22px);
    color: var(--gray-700);
    line-height: 1.5;
    max-width: 36ch;
    margin: 0;
  }

  /* Editorial service index — hairline list, no card boxes */
  .svc-index-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--gray-200);
  }
  .svc-index-list li {
    border-bottom: 1px solid var(--gray-200);
  }
  .svc-index-list a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    min-height: 52px;
    padding: 6px 6px 6px 2px;
    color: var(--ink);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }
  .svc-index-list a:hover {
    color: var(--blue-700);
  }
  .svc-index-list .n {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--gray-500);
    min-width: 24px;
  }
  .svc-index-list a:hover .n {
    color: var(--blue-700);
  }
  .svc-index-list .t {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(15px, 1.6vw, 17px);
    letter-spacing: -0.01em;
  }
  .svc-index-list .ar {
    color: var(--gray-300);
    transform: translateX(-4px);
    opacity: 0;
    transition: transform 0.25s cubic-bezier(.2,.8,.2,1), opacity 0.25s;
  }
  .svc-index-list a:hover .ar {
    color: var(--blue-700);
    transform: translateX(0);
    opacity: 1;
  }

  /* ===== Mosaic section ===== */
  .svc-mosaic-head {
    margin-bottom: clamp(40px, 6vh, 60px);
  }
  .svc-mosaic-head h2 {
    font-family: var(--font-display);
    font-size: clamp(34px, 5vw, 64px);
    line-height: 0.96;
    letter-spacing: -0.03em;
    font-weight: 700;
    max-width: 760px;
    margin: 12px 0 0;
    text-wrap: balance;
  }

  /* ===== Calm reveal (transform/opacity only, motion-guarded below) ===== */
  @media (prefers-reduced-motion: no-preference) {
    .svc-rev {
      opacity: 0;
      transform: translateY(22px);
      transition:
        opacity 0.7s cubic-bezier(.2,.8,.2,1),
        transform 0.7s cubic-bezier(.2,.8,.2,1);
      will-change: transform, opacity;
    }
    .svc-rev.in {
      opacity: 1;
      transform: none;
      will-change: auto;
    }
    /* Soft cadence on the hero stack */
    .svc-h1.svc-rev { transition-delay: 0.05s; }
    .svc-hero-foot .svc-lede.svc-rev { transition-delay: 0.1s; }
    .svc-hero-foot .svc-index-list.svc-rev { transition-delay: 0.16s; }
    .svc-mosaic-head h2.svc-rev { transition-delay: 0.06s; }

    /* Mosaic tiles enter with a gentle stagger; index set per tile in script */
    .svc-mosaic-mount :global(.svc) {
      opacity: 0;
      transform: translateY(26px);
      transition:
        opacity 0.7s cubic-bezier(.2,.8,.2,1),
        transform 0.7s cubic-bezier(.2,.8,.2,1);
      transition-delay: calc(var(--svc-i, 0) * 0.07s);
      will-change: transform, opacity;
    }
    .svc-mosaic-mount.in :global(.svc) {
      opacity: 1;
      transform: none;
      will-change: auto;
    }
  }

  /* ===== Mobile ===== */
  @media (max-width: 860px) {
    .svc-hero-foot {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 32px;
    }
    .svc-lede { max-width: none; }
    .svc-index-list a {
      min-height: 56px;
      padding: 10px 4px 10px 2px;
    }
    .svc-index-list .ar {
      opacity: 1;
      transform: none;
      color: var(--gray-500);
    }
  }
</style>

<script>
  import { initMotion, prefersReducedMotion } from '../../lib/motion';

  initMotion();

  if (!prefersReducedMotion() && 'IntersectionObserver' in window) {
    // Reveal hero/section blocks and the mosaic mount on scroll-in.
    const targets = document.querySelectorAll<HTMLElement>('[data-svc-rev], [data-svc-mosaic]');

    // Tag each mosaic tile with a stagger index (consumed by --svc-i in CSS).
    const mount = document.querySelector<HTMLElement>('[data-svc-mosaic]');
    mount?.querySelectorAll<HTMLElement>('.svc').forEach((tile, i) => {
      tile.style.setProperty('--svc-i', String(i));
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.14 },
    );
    targets.forEach((el) => io.observe(el));

    document.addEventListener(
      'astro:before-swap',
      () => io.disconnect(),
      { once: true },
    );
  }
</script>
