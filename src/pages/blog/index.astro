---
import Layout from '../../layouts/Layout.astro';
import { BLOG_POSTS, BLOG_CATEGORIES } from '../../data/site.ts';

const featured = BLOG_POSTS[0];
const rest = BLOG_POSTS.slice(1);
---
<Layout title="Blog — Generando Ideas" description="Tendencias, casos reales, guías técnicas y opiniones de nuestro equipo sobre artículos promocionales.">
  <div class="page blog-page">
    <section class="section blog-hero">
      <div class="wrap">
        <span class="eyebrow">Blog · Ideas en acción</span>
        <h1 class="blog-h1 display">
          Lo que aprendemos, <span class="text-grad-word">lo compartimos.</span>
        </h1>
        <p class="blog-lead">
          Tendencias, casos reales, guías técnicas y opiniones de nuestro equipo.
        </p>
      </div>
    </section>

    <section class="section blog-body">
      <div class="wrap">
        <div class="cat-filter blog-filter" id="blog-filter" role="tablist" aria-label="Filtrar artículos por categoría">
          {BLOG_CATEGORIES.map((c, i) => (
            <button
              class:list={['chip', { active: i === 0 }]}
              data-cat={c}
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >{c}</button>
          ))}
        </div>

        <div id="blog-content">
          <a class="blog-feature reveal" href={`/blog/${featured.id}`}>
            <div class="blog-feature-img">
              <img src={featured.img} alt={featured.title} loading="lazy" />
            </div>
            <div class="blog-feature-body">
              <span class="eyebrow">Destacado · {featured.cat}</span>
              <h2 class="blog-feature-title display">
                {featured.title}
              </h2>
              <p class="blog-feature-excerpt">{featured.excerpt}</p>
              <span class="blog-meta">
                {featured.date} · {featured.read} lectura
              </span>
            </div>
          </a>

          <div class="blog-grid reveal">
            {rest.map((p, i) => (
              <a class="blog-card" href={`/blog/${p.id}`} style={`--i:${i}`}>
                <div class="blog-card-img"><img src={p.img} alt={p.title} loading="lazy" /></div>
                <div class="blog-card-body">
                  <span class="blog-card-cat">{p.cat}</span>
                  <h3 class="blog-card-title">{p.title}</h3>
                  <p class="blog-card-excerpt">{p.excerpt}</p>
                  <span class="blog-card-meta">{p.date} · {p.read}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    /* ----- Hero ----- */
    .blog-hero { padding-bottom: 40px; }
    .blog-h1 {
      font-size: clamp(52px, 8vw, 116px);
      margin: 20px 0 28px;
      max-width: 16ch;
      letter-spacing: -0.035em;
      line-height: 0.94;
      text-wrap: balance;
    }
    .blog-lead {
      font-size: clamp(18px, 2.2vw, 21px);
      color: var(--gray-700);
      line-height: 1.5;
      max-width: 56ch;
      margin: 0;
    }

    /* ----- Body / filter ----- */
    .blog-body { padding-top: 0; }
    .blog-filter { margin-bottom: 40px; }
    /* Tap-target floor: the global .chip is ~40px tall; bring it to >= 44px. */
    .blog-filter .chip { min-height: 44px; display: inline-flex; align-items: center; }

    /* ----- Featured ----- */
    .blog-feature-title {
      font-size: clamp(34px, 4.5vw, 56px);
      margin: 12px 0 16px;
      letter-spacing: -0.025em;
      line-height: 1;
      text-wrap: balance;
    }
    .blog-feature-excerpt {
      color: var(--gray-700);
      font-size: 17px;
      line-height: 1.55;
      margin: 0 0 22px;
      max-width: 52ch;
    }
    .blog-meta,
    .blog-card-meta {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--gray-500);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    /* Soften the global featured-image hover so inner pages stay calmer. */
    @media (prefers-reduced-motion: no-preference) {
      .blog-feature:hover .blog-feature-img img { transform: scale(1.04); }
    }

    /* ----- Cards ----- */
    .blog-card-cat {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--blue-700);
    }
    .blog-card-title {
      font-family: var(--font-display);
      font-size: 23px;
      margin: 8px 0 10px;
      letter-spacing: -0.02em;
      line-height: 1.12;
      font-weight: 600;
    }
    .blog-card-excerpt {
      color: var(--gray-700);
      font-size: 14px;
      line-height: 1.55;
      margin: 0 0 18px;
      flex: 1;
    }
    .blog-card-meta { font-size: 12px; }

    /* Empty state (used when a category has no posts after filtering). */
    .blog-empty {
      color: var(--gray-500);
      font-size: 16px;
      line-height: 1.5;
      padding: 40px 0;
      margin: 0;
    }

    /* Per-card stagger for the GSAP grid reveal. Purely transform/opacity and
       only consumed when motion is allowed (see the script guard). The custom
       property is set inline (--i) so re-rendered nodes inherit it too. */
    @media (prefers-reduced-motion: no-preference) {
      .blog-grid .blog-card {
        opacity: 0;
        transform: translateY(24px);
      }
      .blog-grid.in .blog-card {
        opacity: 1;
        transform: none;
        transition:
          opacity 0.6s cubic-bezier(.2, .8, .2, 1),
          transform 0.6s cubic-bezier(.2, .8, .2, 1);
        transition-delay: calc(var(--i, 0) * 0.06s);
      }
    }

    @media (max-width: 860px) {
      .blog-h1 { max-width: none; }
      .blog-feature-excerpt { max-width: none; }
    }

    /* Reduced-motion: no offsets, no transitions — fully visible immediately.
       (Backs up the global .reveal reduced-motion reset for the staggered grid.) */
    @media (prefers-reduced-motion: reduce) {
      .blog-grid .blog-card { opacity: 1; transform: none; }
    }
  </style>

  <script define:vars={{ posts: BLOG_POSTS }}>
    const filter = document.getElementById('blog-filter');
    const content = document.getElementById('blog-content');

    const esc = (s) =>
      String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]);

    const featuredHTML = (p) => `
      <a class="blog-feature reveal" href="/blog/${p.id}">
        <div class="blog-feature-img"><img src="${esc(p.img)}" alt="${esc(p.title)}" loading="lazy" /></div>
        <div class="blog-feature-body">
          <span class="eyebrow">Destacado · ${esc(p.cat)}</span>
          <h2 class="blog-feature-title display">${esc(p.title)}</h2>
          <p class="blog-feature-excerpt">${esc(p.excerpt)}</p>
          <span class="blog-meta">${esc(p.date)} · ${esc(p.read)} lectura</span>
        </div>
      </a>`;

    const cardHTML = (p, i) => `
      <a class="blog-card" href="/blog/${p.id}" style="--i:${i}">
        <div class="blog-card-img"><img src="${esc(p.img)}" alt="${esc(p.title)}" loading="lazy" /></div>
        <div class="blog-card-body">
          <span class="blog-card-cat">${esc(p.cat)}</span>
          <h3 class="blog-card-title">${esc(p.title)}</h3>
          <p class="blog-card-excerpt">${esc(p.excerpt)}</p>
          <span class="blog-card-meta">${esc(p.date)} · ${esc(p.read)}</span>
        </div>
      </a>`;

    function render(cat) {
      const filtered = cat === 'Todos' ? posts : posts.filter((p) => p.cat === cat);
      const featured = filtered[0];
      const rest = filtered.slice(1);
      let html = featured ? featuredHTML(featured) : '';
      html += `<div class="blog-grid reveal">${rest.map((p, i) => cardHTML(p, i)).join('')}</div>`;
      if (!filtered.length) {
        html += '<p class="blog-empty">Aún no hay artículos en esta categoría. Pronto compartiremos más.</p>';
      }
      content.innerHTML = html;
      // Freshly injected nodes aren't seen by the load-time reveal observer,
      // so play their fade-up on the next frame (matches the prototype's
      // re-render, which re-ran its IntersectionObserver on filter change).
      // Adding .in on the grid also fires the per-card staggered transition.
      requestAnimationFrame(() => {
        content.querySelectorAll('.reveal:not(.in)').forEach((el) => el.classList.add('in'));
      });
    }

    filter?.querySelectorAll('.chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        filter.querySelectorAll('.chip').forEach((c) => {
          const active = c === chip;
          c.classList.toggle('active', active);
          c.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        render(chip.dataset.cat);
      });
    });
  </script>

  <script>
    import { initMotion, ScrollTrigger } from '../../lib/motion';

    // Smooth scroll (Lenis) to match the homepage feel. The actual fade-up of
    // the featured block and the card grid is handled by the global reveal
    // IntersectionObserver in Layout.astro (it adds `.in` to `.reveal` nodes);
    // the per-card cascade is then driven purely by CSS (--i + .blog-grid.in).
    // The JS category filter re-adds `.in` on its freshly injected nodes, so the
    // cascade replays on every filter change. Everything is transform/opacity
    // only and reduced-motion is honoured by the global rule + the scoped media
    // queries above.
    initMotion();

    // Tear down any ScrollTriggers Lenis registered on Astro view transitions so
    // nothing leaks across pages.
    document.addEventListener(
      'astro:before-swap',
      () => ScrollTrigger.getAll().forEach((t) => t.kill()),
      { once: true },
    );
  </script>
</Layout>
