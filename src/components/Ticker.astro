---
import { TICKER_WORDS } from '../data/site.ts';
// Static band: a single centered row that wraps instead of scrolling, so no
// word (e.g. "Promotional Workshop") is ever clipped at the container edge.
const words = TICKER_WORDS;
---
<div class="ticker" aria-hidden="true">
  <div class="ticker-marquee">
    {words.map((w, i) => (
      <span class="ticker-item">
        {w}{i < words.length - 1 && <b class="ticker-dot"> · </b>}
      </span>
    ))}
  </div>
</div>

<style>
  .ticker {
    position: relative;
    background: var(--ink);
    color: var(--paper);
    padding: 20px 24px;
  }

  /* Centered, wrapping row — static (no transform), so nothing is clipped. */
  .ticker-marquee {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    max-width: var(--max);
    margin: 0 auto;
  }

  .ticker-item {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 4px 8px;
    line-height: 1;
  }

  .ticker-dot {
    color: var(--orange-500);
    font-weight: 700;
    margin: 0 8px;
  }

  @media (max-width: 860px) {
    .ticker { padding: 16px 20px; }
    .ticker-item { font-size: 22px; }
  }
</style>
