---
import { ROUTES } from '../data/site.ts';
---

<section class="section closing" data-closing>
  <div class="wrap closing-inner">
    <h2 class="closing-h reveal">
      ¿Listo para <span class="text-grad-word">impulsar</span> tu marca?
    </h2>
    <p class="closing-sub reveal">
      Cuéntanos qué traes en mente. Te respondemos con propuesta y cotización en menos de 48 horas.
    </p>
    <div class="closing-cta reveal">
      <span class="magnetic" data-magnetic>
        <a href={ROUTES.contact} class="btn btn-accent btn-lg">
          Cotizar
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </span>
      <a href={ROUTES.catalog} class="btn btn-ghost btn-lg">Ver catálogo</a>
    </div>
  </div>
</section>

<style>
  .closing {
    background: var(--blue-700);
    color: #fff;
    text-align: center;
    overflow: hidden;
  }

  .closing-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .closing-h {
    font-family: var(--font-display);
    font-size: clamp(38px, 5.5vw, 84px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    font-weight: 700;
    max-width: 16ch;
    margin: 0;
    text-wrap: balance;
  }

  .closing-sub {
    color: rgba(255, 255, 255, 0.82);
    font-size: 18px;
    line-height: 1.5;
    max-width: 52ch;
    margin: 0;
  }

  /* Sobre la banda gris oscura el acento va en naranja claro de marca
     (el manual no contempla degradados). */
  .closing .text-grad-word {
    color: var(--orange-300);
  }

  .closing-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  /* The magnetic wrapper must be inline-block so its transform pulls the button
     without affecting the surrounding flex layout. will-change is set only when
     motion is allowed (see the no-preference guard below). */
  .magnetic {
    display: inline-block;
  }

  .magnetic .btn-accent {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* Tap target: btn-lg is already >= 44px tall, but enforce it explicitly so the
     anchors never drop below the accessibility floor on any viewport. */
  .closing .btn-lg {
    min-height: 44px;
  }

  /* Ghost button recolored for the dark blue band (global .btn-ghost is tuned
     for light surfaces). */
  .closing .btn-ghost {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }
  .closing .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #fff;
  }

  /* Stagger the three revealed blocks for a touch of cadence. Guarded so
     reduced-motion users get no delay (and the global reduced-motion rule keeps
     them fully visible). */
  @media (prefers-reduced-motion: no-preference) {
    .magnetic {
      will-change: transform;
    }
    .closing-sub {
      transition-delay: 0.08s;
    }
    .closing-cta {
      transition-delay: 0.16s;
    }
  }

  @media (max-width: 860px) {
    .closing-sub {
      font-size: 16px;
    }
    .closing-cta {
      width: 100%;
    }
    /* Full-width, comfortably tappable buttons in the single-column layout. */
    .closing-cta .magnetic,
    .closing-cta > .btn {
      width: 100%;
    }
    .closing-cta .magnetic .btn-accent {
      width: 100%;
      justify-content: center;
    }
    .closing-cta > .btn-ghost {
      justify-content: center;
    }
  }
</style>

<script>
  import { gsap, prefersReducedMotion } from '../lib/motion';

  const wrap = document.querySelector<HTMLElement>('[data-magnetic]');

  // Magnet only on fine-pointer (mouse) devices, with motion allowed. Touch and
  // reduced-motion users get a plain, static button.
  if (
    wrap &&
    !prefersReducedMotion() &&
    window.matchMedia('(pointer: fine)').matches
  ) {
    const xTo = gsap.quickTo(wrap, 'x', { duration: 0.4, ease: 'power3' });
    const yTo = gsap.quickTo(wrap, 'y', { duration: 0.4, ease: 'power3' });

    const onMove = (e: PointerEvent) => {
      const r = wrap.getBoundingClientRect();
      xTo((e.clientX - (r.left + r.width / 2)) * 0.35);
      yTo((e.clientY - (r.top + r.height / 2)) * 0.35);
    };
    const onLeave = () => {
      xTo(0);
      yTo(0);
    };

    wrap.addEventListener('pointermove', onMove);
    wrap.addEventListener('pointerleave', onLeave);

    // Teardown on Astro view transitions so listeners/tweens don't leak.
    document.addEventListener(
      'astro:before-swap',
      () => {
        wrap.removeEventListener('pointermove', onMove);
        wrap.removeEventListener('pointerleave', onLeave);
        gsap.killTweensOf(wrap);
      },
      { once: true }
    );
  }
</script>
