---
import { BRAND, ROUTES, SERVICES } from '../data/site.ts';
import SocialIcons from './SocialIcons.astro';
---
<footer class="footer">
  <div class="wrap">
    <a href={ROUTES.home} class="footer-logo" aria-label="Generando Ideas — inicio">
      <img src="/brand/logo-horizontal-blanco.svg" alt="Generando Ideas" width="282" height="63" decoding="async" />
    </a>
    <div class="footer-brand">
      Vivimos de <em>promocionales.</em>
    </div>
    <div class="footer-grid reveal">
      <div>
        <h3>Contáctanos</h3>
        <p style="color: var(--gray-300); font-size: 14px; line-height: 1.6; margin: 0;">
          {BRAND.phone}<br />
          {BRAND.email}<br />
          CDMX · Sonora · Yucatán
        </p>
        <SocialIcons variant="footer" />
        <p class="footer-slogan" aria-label="Your one stop solution">
          Your one<br />stop<br />solution<span class="r">®</span>
        </p>
      </div>
      <div>
        <h3>Empresa</h3>
        <ul>
          <li><a href={ROUTES.about}>Conócenos</a></li>
          <li><a href={ROUTES.about}>Propósito</a></li>
          <li><a href={ROUTES.about}>Principios</a></li>
        </ul>
      </div>
      <div>
        <h3>Servicios</h3>
        <ul>
          {SERVICES.map((s) => (
            <li><a href={ROUTES.service(s.id)}>{s.title}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3>Recursos</h3>
        <ul>
          <li><a href={ROUTES.catalog}>Catálogos</a></li>
          <li><a href={ROUTES.blog}>Blog</a></li>
          <li><a href={ROUTES.careers}>Bolsa de trabajo</a></li>
          <li><a href="https://api.generandoideas.com" target="_blank" rel="noopener noreferrer">e-Store</a></li>
          <li>
            <a href={ROUTES.privacy} target="_blank" rel="noopener noreferrer">Aviso de privacidad</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Generando Ideas. Todos los derechos reservados.</span>
      <span>100% Empresa Mexicana · <svg width="7" height="7" viewBox="0 0 8 8" aria-hidden="true" style="display:inline-block;vertical-align:middle;"><circle cx="4" cy="4" r="4" fill="var(--orange-500)" /></svg> MX</span>
    </div>
  </div>
</footer>

<style>
  .footer-logo {
    display: inline-block;
    margin-bottom: 28px;
  }
  .footer-logo img {
    display: block;
    width: clamp(160px, 17.6vw, 226px);
    height: auto;
  }
  .footer-slogan {
    font-family: var(--font-slogan);
    font-size: 34px;
    line-height: 0.92;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--orange-500);
    margin: 24px 0 0;
  }
  .footer-slogan .r {
    font-size: 0.35em;
    vertical-align: super;
  }
</style>
