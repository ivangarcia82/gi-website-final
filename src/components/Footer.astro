---
import { BRAND, ROUTES } from '../data/site.ts';
---
<footer class="footer">
  <div class="wrap">
    <a href={ROUTES.home} class="footer-logo" aria-label="Generando Ideas — inicio">
      <img src="/brand/logo-horizontal-blanco.svg" alt="Generando Ideas" width="282" height="63" loading="lazy" />
    </a>
    <div class="footer-brand">
      Vivimos de <em>promocionales.</em>
    </div>
    <div class="footer-grid reveal">
      <div>
        <h3>Contáctanos</h3>
        <p style="color: var(--gray-300); font-size: 14px; line-height: 1.6; margin: 0;">
          {BRAND.phone}<br />
          {BRAND.email}<br />
          CDMX · Sonora · Yucatán · BCS
        </p>
        <p class="footer-slogan" aria-label="Your one stop solution">
          Your one<br />stop<br />solution<span class="r">®</span>
        </p>
      </div>
      <div>
        <h3>Empresa</h3>
        <ul>
          <li><a href={ROUTES.about}>Conócenos</a></li>
          <li><a href={ROUTES.about}>Misión</a></li>
          <li><a href={ROUTES.about}>Visión</a></li>
          <li><a href={ROUTES.about}>Valores</a></li>
        </ul>
      </div>
      <div>
        <h3>Servicios</h3>
        <ul>
          <li><a href={ROUTES.services}>Promocionales</a></li>
          <li><a href={ROUTES.services}>Fulfillment</a></li>
          <li><a href={ROUTES.services}>Proyectos Especiales</a></li>
          <li><a href={ROUTES.services}>Talleres</a></li>
          <li><a href={ROUTES.services}>Textiles</a></li>
        </ul>
      </div>
      <div>
        <h3>Recursos</h3>
        <ul>
          <li><a href={ROUTES.catalog}>Catálogos</a></li>
          <li><a href={ROUTES.blog}>Blog</a></li>
          <li><a href={ROUTES.careers}>Bolsa de trabajo</a></li>
          <li><a>e-Store</a></li>
          <li><a>Responsabilidad social</a></li>
          <li><a>Aviso de privacidad</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Generando Ideas · 100% Empresa Mexicana</span>
      <span>Hecho con ideas · <svg width="7" height="7" viewBox="0 0 8 8" aria-hidden="true" style="display:inline-block;vertical-align:middle;"><circle cx="4" cy="4" r="4" fill="var(--orange-500)" /></svg> MX</span>
    </div>
  </div>
</footer>

<style>
  .footer-logo {
    display: inline-block;
    margin-bottom: 28px;
  }
  .footer-logo img {
    display: block;
    width: clamp(200px, 22vw, 282px);
    height: auto;
  }
  /* Eslogan oficial: Bebas Neue, siempre en tres líneas (manual de marca). */
  .footer-slogan {
    font-family: var(--font-slogan);
    font-size: 34px;
    line-height: 0.92;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--orange-500);
    margin: 24px 0 0;
  }
  .footer-slogan .r {
    font-size: 0.35em;
    vertical-align: super;
  }
</style>
