---
// Logotipo oficial Generando Ideas — versión horizontal (manual de marca:
// "Header principal: Horizontal"). variant="blanco" para fondos oscuros.
export interface Props {
  variant?: 'color' | 'blanco';
}
const { variant = 'color' } = Astro.props;
const src = variant === 'blanco' ? '/brand/logo-horizontal-blanco.svg' : '/brand/logo-horizontal.svg';
---
<img
  class="logo"
  src={src}
  alt="Generando Ideas"
  width="282"
  height="63"
/>

<style>
  /* Mínimo digital del manual: 282 × 60 px para la versión horizontal.
     Reducido para dejar más aire (safe space) alrededor del logo en el header. */
  .logo {
    display: block;
    width: clamp(140px, 16vw, 196px);
    height: auto;
  }
</style>
