---
import { NAV_ITEMS, ROUTES } from '../data/site.ts';

// Determine the active nav item from the current path (mirrors Nav.astro).
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string): boolean {
  if (href === '/' || href === '/servicios') return path === href;
  return path === href || path.startsWith(href + '/');
}
---
<div class="drawer" id="drawer" aria-hidden="true">
  <div class="drawer-scrim" data-drawer-close></div>
  <nav class="drawer-panel" aria-label="Menú móvil">
    <button class="drawer-close" data-drawer-close aria-label="Cerrar menú">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
    {NAV_ITEMS.map((p) => (
      <a href={p.href} class:list={['drawer-link', { active: isActive(p.href) }]}>
        {p.label}
      </a>
    ))}
    <a href={ROUTES.contact} class="btn btn-accent drawer-cta">
      Cotiza tu proyecto
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6" />
      </svg>
    </a>
  </nav>
</div>

<style>
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: none;
  }
  .drawer.open {
    display: block;
  }
  .drawer-scrim {
    position: absolute;
    inset: 0;
    background: rgba(16, 17, 20, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .drawer.open .drawer-scrim {
    opacity: 1;
  }
  .drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(86vw, 360px);
    max-width: 100%;
    background: var(--paper);
    border-left: 1px solid var(--gray-200);
    box-shadow: var(--shadow-lg);
    padding: 20px 24px calc(24px + env(safe-area-inset-bottom, 0px));
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow-y: auto;
  }
  .drawer.open .drawer-panel {
    transform: none;
  }
  .drawer-close {
    align-self: flex-end;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    display: grid;
    place-items: center;
    color: var(--ink);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background 0.18s;
  }
  .drawer-close:hover {
    background: var(--gray-100);
  }
  .drawer-link {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    padding: 12px 8px;
    border-radius: var(--radius-sm);
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.18s, background 0.18s;
  }
  .drawer-link:hover {
    background: var(--gray-100);
  }
  .drawer-link.active {
    color: var(--blue-700);
  }
  .drawer-cta {
    margin-top: 16px;
    justify-content: center;
    min-height: 48px;
  }

  @media (prefers-reduced-motion: reduce) {
    .drawer-scrim,
    .drawer-panel {
      transition: none;
    }
  }
</style>

<script>
  const drawer = document.getElementById('drawer');
  const openBtn = document.querySelector<HTMLElement>('[data-drawer-open]');
  const panel = drawer?.querySelector<HTMLElement>('.drawer-panel') ?? null;
  let lastFocus: HTMLElement | null = null;

  function focusableNodes(): HTMLElement[] {
    if (!panel) return [];
    return Array.from(
      panel.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )
    ).filter((el) => el.offsetParent !== null || el === document.activeElement);
  }

  function open() {
    if (!drawer) return;
    lastFocus = document.activeElement as HTMLElement | null;
    drawer.classList.add('open');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    openBtn?.setAttribute('aria-expanded', 'true');
    (drawer.querySelector('.drawer-close') as HTMLElement | null)?.focus();
  }

  function close() {
    if (!drawer) return;
    drawer.classList.remove('open');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    openBtn?.setAttribute('aria-expanded', 'false');
    lastFocus?.focus();
  }

  function trapFocus(e: KeyboardEvent) {
    if (e.key !== 'Tab') return;
    const nodes = focusableNodes();
    if (nodes.length === 0) return;
    const first = nodes[0];
    const last = nodes[nodes.length - 1];
    const active = document.activeElement;
    if (e.shiftKey) {
      if (active === first || !panel?.contains(active)) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (active === last || !panel?.contains(active)) {
        e.preventDefault();
        first.focus();
      }
    }
  }

  openBtn?.addEventListener('click', open);
  drawer
    ?.querySelectorAll('[data-drawer-close]')
    .forEach((el) => el.addEventListener('click', close));

  document.addEventListener('keydown', (e) => {
    if (!drawer?.classList.contains('open')) return;
    if (e.key === 'Escape') {
      close();
    } else if (e.key === 'Tab') {
      trapFocus(e);
    }
  });

  // Restore body scroll if the drawer is torn down during a view transition.
  document.addEventListener(
    'astro:before-swap',
    () => {
      document.body.style.overflow = '';
    },
    { once: true }
  );
</script>
