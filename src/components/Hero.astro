---
---
<section class="hero-cine">
  <div class="hero-stage" data-hero-stage>
    <img
      src="/bannerupdated.jpg"
      alt="Your one stop solution — productos promocionales personalizados de Generando Ideas"
      width="1440"
      height="400"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      data-hero-img
    />
  </div>
  <div class="wrap">
    <div class="hero-meta">
      <div class="hero-badge">
        <div class="t">Edición 2026</div>
        <div class="v">+5,000 productos personalizables</div>
      </div>
      <div class="hero-chips">
        <div class="stat"><strong>11</strong><span>Catálogos</span></div>
        <div class="stat"><strong>3</strong><span>Sucursales MX</span></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-cine {
    position: relative;
    padding: clamp(12px, 2vh, 24px) 0 0;
  }

  /* Aspect-matched stage so `contain` shows the full banner without cropping or
     upscaling past its native size (no pixelation). */
  .hero-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1440 / 400;
    max-height: 70vh;
    background: var(--paper-2);
    overflow: hidden;
  }
  .hero-stage img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Meta strip below the hero (badge + chips), styled for a light background. */
  .hero-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px 40px;
    padding: clamp(20px, 3vh, 32px) 0;
    border-bottom: 1px solid var(--gray-200);
  }
  .hero-badge {
    border-left: 3px solid var(--orange-500);
    padding-left: 16px;
  }
  .hero-badge .t {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange-500);
  }
  .hero-badge .v {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: -0.01em;
    margin-top: 2px;
    color: var(--ink);
  }

  .hero-chips {
    display: flex;
    gap: 40px;
  }
  .hero-chips .stat strong {
    color: var(--ink);
  }
  .hero-chips .stat span {
    color: var(--gray-700);
  }

  @media (max-width: 860px) {
    .hero-chips {
      gap: 28px;
    }
  }
</style>

<script>
  // Initialize smooth scroll (Lenis) for the home page. The banner is shown with
  // object-fit: contain and no parallax zoom, so it never upscales past its
  // native size (no pixelation).
  import { initMotion, ScrollTrigger } from '../lib/motion';

  initMotion();

  document.addEventListener(
    'astro:before-swap',
    () => ScrollTrigger.getAll().forEach((t) => t.kill()),
    { once: true },
  );
</script>
